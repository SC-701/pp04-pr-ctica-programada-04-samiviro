<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="Portal de gestión de vehículos" />
    <meta name="author" content="SC-701" />
    <title>@ViewData["Title"] - Vehículos</title>
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="~/css/styles.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/Vehiculos.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous">

</head>
<body>
    <div class="portal-shell">
        

        <main class="portal-main">
            <div class="mobile-topbar">
                <div>
                    <div class="brand-title">DriveOps</div>
                    <div class="workspace-subtitle">Gestión vehicular</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn-shell-outline" href="/">Inicio</a>
                    <a class="btn-shell-outline" href="/Vehiculos">Vehículos</a>
                </div>
            </div>

            <div class="workspace">
                <div class="workspace-header">
                    <div>
                        <h1 class="workspace-title">Sistema de vehículos</h1>
                    </div>
                    <div class="workspace-meta">Programación Web Avanzada</div>
                </div>

                @RenderBody()

                
            </div>
        </main>
    </div>

    <script src="/lib/jquery/dist/jquery.js"></script>
    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js" asp-append-version="true"></script>
    <script src="/js/scripts.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
